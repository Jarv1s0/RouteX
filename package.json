{
  "name": "routex",
  "version": "4.0.0",
  "description": "RouteX",
  "author": "Jarv1s0",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:ci": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "typecheck:node": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "corepack pnpm run typecheck:node && corepack pnpm run typecheck:web && cargo check --manifest-path src-tauri/Cargo.toml",
    "prepare:resources": "node scripts/prepare.mjs",
    "start": "vite preview --configLoader runner --config vite.tauri.config.ts",
    "dev": "tauri dev",
    "dev:tauri-web": "vite --configLoader runner --config vite.tauri.config.ts",
    "build:tauri-web": "vite build --configLoader runner --config vite.tauri.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build": "corepack pnpm run prepare:resources && corepack pnpm run typecheck && tauri build",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify": "corepack pnpm run typecheck && corepack pnpm run test:rust && corepack pnpm run build:tauri-web",
    "build:win": "corepack pnpm run build",
    "build:mac": "corepack pnpm run build",
    "build:linux": "corepack pnpm run build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "adm-zip": "^0.5.16",
    "dayjs": "^1.11.19",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^9.39.1",
    "@heroui/react": "2.8.5",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/dagre": "^0.7.53",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.3",
    "@types/pubsub-js": "^1.8.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "echarts": "^6.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "framer-motion": "12.23.26",
    "is-cidr": "^6.0.1",
    "is-ip": "^5.0.1",
    "lodash": "^4.18.0",
    "meta-json-schema": "^1.19.23",
    "monaco-yaml": "^5.4.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "prettier": "^3.7.4",
    "pubsub-js": "^1.9.5",
    "react": "^19.2.1",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-monaco-editor": "^0.59.0",
    "react-router-dom": "^7.12.0",
    "react-virtuoso": "^4.17.0",
    "sonner": "^2.0.7",
    "spark-md5": "^3.0.2",
    "swr": "^2.3.7",
    "tailwindcss": "^4.1.17",
    "tar": "^7.5.10",
    "types-pac": "^1.0.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-monaco-editor": "1.1.0",
    "zustand": "^5.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "tauri-cli"
    ],
    "patchedDependencies": {
      "vite-plugin-monaco-editor@1.1.0": "patches/vite-plugin-monaco-editor@1.1.0.patch"
    },
    "overrides": {
      "follow-redirects": "^1.16.0",
      "qs": ">=6.14.2",
      "tar": "^7.5.11",
      "flatted": "^3.4.2",
      "yauzl": "^3.2.1",
      "@tootallnate/once": ">=3.0.1",
      "fast-xml-parser": "^5.5.7",
      "@isaacs/brace-expansion": "^5.0.1",
      "brace-expansion": "^5.0.5",
      "picomatch": "^4.0.4",
      "rollup": ">=4.59.0",
      "minimatch": ">=10.2.4",
      "path-to-regexp": ">=8.4.0",
      "@xmldom/xmldom": "0.8.12"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-26996"
      ]
    }
  },
  "packageManager": "pnpm@10.15.0"
}

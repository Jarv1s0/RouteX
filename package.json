{
  "name": "routex",
  "version": "3.2.0",
  "description": "RouteX",
  "author": "Jarv1s0",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:ci": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "typecheck:node": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "corepack pnpm run typecheck:node && corepack pnpm run typecheck:web",
    "prepare:resources": "node scripts/prepare.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "corepack pnpm run prepare:resources && corepack pnpm run typecheck && electron-vite build",
    "verify": "corepack pnpm run prepare:resources && corepack pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "corepack pnpm run build && electron-builder --config electron-builder.config.cjs --dir",
    "build:win": "corepack pnpm run build && electron-builder --config electron-builder.config.cjs --win --publish always",
    "build:mac": "corepack pnpm run build && electron-builder --config electron-builder.config.cjs --mac --publish always",
    "build:linux": "corepack pnpm run build && electron-builder --config electron-builder.config.cjs --linux --publish always"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.15.1",
    "dayjs": "^1.11.19",
    "express": "^5.2.1",
    "file-icon": "^6.0.0",
    "file-icon-info": "^1.1.1",
    "iconv-lite": "^0.7.1",
    "webdav": "^5.8.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@heroui/react": "2.8.5",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",

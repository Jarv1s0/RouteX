    "is-ip": "^5.0.1",
    "lodash": "^4.18.0",
    "meta-json-schema": "^1.19.24",
    "monaco-yaml": "^5.4.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "pubsub-js": "^1.9.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^6.0.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-monaco-editor": "^0.59.0",
    "react-countup": "^6.5.3",
    "react-router-dom": "^7.12.0",

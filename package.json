{
  "name": "routex",
  "version": "4.3.0",
  "description": "RouteX",
  "author": "Jarv1s0",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:ci": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "typecheck:node": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "typecheck": "run-p typecheck:*",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "check:ipc-contract": "node scripts/check-ipc-contract.mjs",
    "check:dead-code": "node scripts/check-dead-code.mjs",
    "check:release-env": "node scripts/check-release-env.mjs",
    "audit:node": "node scripts/check-node-audit.mjs",
    "audit:rust": "node scripts/check-rust-audit.mjs",
    "prepare:resources": "node scripts/prepare.mjs",
    "start": "vite preview --configLoader runner --config vite.tauri.config.ts",
    "dev": "tauri dev --no-watch",
    "dev:tauri-web": "vite --configLoader runner --config vite.tauri.config.ts",
    "build:tauri-web": "vite build --configLoader runner --config vite.tauri.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --no-watch",
    "tauri:build": "tauri build",
    "build": "corepack pnpm run prepare:resources && corepack pnpm run check:release-env && corepack pnpm run typecheck && tauri build",
    "test:web": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify": "corepack pnpm run lint:ci && corepack pnpm run typecheck && corepack pnpm run clippy && corepack pnpm run check:ipc-contract && corepack pnpm run check:dead-code && corepack pnpm run test:web && corepack pnpm run audit:node && corepack pnpm run audit:rust && corepack pnpm run test:rust && corepack pnpm run build:tauri-web",
    "analyze": "cross-env ANALYZE=true corepack pnpm run build:tauri-web",
    "build:win": "corepack pnpm run build",
    "build:mac": "corepack pnpm run build",
    "build:linux": "corepack pnpm run build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "dayjs": "^1.11.19",
    "js-yaml": "^4.3.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^9.39.1",
    "@heroui/react": "2.8.5",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2.11.0",
    "@types/dagre": "^0.7.53",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@xyflow/react": "^12.10.1",
    "adm-zip": "^0.6.0",
    "cross-env": "^10.1.0",
    "dagre": "^0.8.5",
    "echarts": "^6.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "is-cidr": "^6.0.1",
    "is-ip": "^5.0.1",
    "next-themes": "^0.4.6",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "react-virtuoso": "^4.17.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sonner": "^2.0.7",
    "spark-md5": "^3.0.2",
    "swr": "^2.3.7",
    "tailwindcss": "^4.1.17",
    "tar": "^7.5.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.5",
    "zustand": "^5.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "tauri-cli"
    ],
    "overrides": {
      "@babel/core": "^7.29.7",
      "follow-redirects": "^1.16.0",
      "qs": ">=6.14.2",
      "tar": "^7.5.18",
      "flatted": "^3.4.2",
      "yauzl": "^3.2.1",
      "@tootallnate/once": ">=3.0.1",
      "fast-xml-parser": "^5.5.7",
      "@isaacs/brace-expansion": "^5.0.1",
      "brace-expansion": "^5.0.7",
      "shell-quote": "^1.9.0",
      "picomatch": "^4.0.4",
      "rollup": ">=4.59.0",
      "minimatch": ">=10.2.4",
      "path-to-regexp": ">=8.4.0",
      "@xmldom/xmldom": "0.8.12",
      "postcss": "8.5.12",
      "esbuild": "0.28.1"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-26996"
      ]
    }
  },
  "packageManager": "pnpm@10.15.0"
}

pkgname=routex-electron-bin
_pkgname=routex
pkgver=2.2.4
pkgrel=1
pkgdesc="Modern Mihomo GUI."
arch=('x86_64')
url="https://github.com/Jarv1s0/RouteX"
license=('GPL3')
conflicts=("$_pkgname" "$_pkgname-git" "$_pkgname-bin" "$_pkgname-electron" "$_pkgname-electron-git")
depends=('electron' 'gtk3' 'libnotify' 'nss' 'libxss' 'libxtst' 'xdg-utils' 'at-spi2-core' 'util-linux-libs' 'libsecret')
optdepends=('libappindicator-gtk3: Allow RouteX to extend a menu via Ayatana indicators in Unity, KDE or Systray (GTK+ 3 library).')
makedepends=('asar')
install=$_pkgname.install
source=("${_pkgname}.desktop" "${_pkgname}.sh")
source_x86_64=("${_pkgname}-${pkgver}-x86_64.deb::${url}/releases/download/v${pkgver}/RouteX-${pkgver}-linux-amd64.deb")
sha256sums=('SKIP' 'SKIP')
sha256sums_x86_64=('SKIP')
options=('!lto')

package() {
    bsdtar -xf data.tar.xz -C $srcdir
    asar extract $srcdir/opt/RouteX/resources/app.asar ${pkgdir}/opt/RouteX
    cp -r $srcdir/opt/RouteX/resources/sidecar ${pkgdir}/opt/RouteX/resources/
    cp -r $srcdir/opt/RouteX/resources/files ${pkgdir}/opt/RouteX/resources/
    chmod +x ${pkgdir}/opt/RouteX/resources/files/routex-service
    chmod +sx ${pkgdir}/opt/RouteX/resources/sidecar/mihomo
    chmod +sx ${pkgdir}/opt/RouteX/resources/sidecar/mihomo-alpha
    install -Dm755 "${srcdir}/${_pkgname}.sh" "${pkgdir}/usr/bin/${_pkgname}"
    install -Dm644 "${_pkgname}.desktop" "${pkgdir}/usr/share/applications/${_pkgname}.desktop"
    install -Dm644 "${pkgdir}/opt/RouteX/resources/icon.png" "${pkgdir}/usr/share/icons/hicolor/512x512/apps/${_pkgname}.png"

    chown -R root:root ${pkgdir}
}

pkgname=routex-electron
_pkgname=routex
pkgver=2.2.4
pkgrel=1
pkgdesc="Modern Mihomo GUI."
arch=('x86_64' 'aarch64')
url="https://github.com/Jarv1s0/RouteX"
license=('GPL3')
conflicts=("$_pkgname" "$_pkgname-git" "$_pkgname-bin" "$_pkgname-electron-bin" "$_pkgname-electron-git")
depends=('electron' 'gtk3' 'libnotify' 'nss' 'libxss' 'libxtst' 'xdg-utils' 'at-spi2-core' 'util-linux-libs' 'libsecret')
optdepends=('libappindicator-gtk3: Allow RouteX to extend a menu via Ayatana indicators in Unity, KDE or Systray (GTK+ 3 library).')
makedepends=('nodejs' 'pnpm' 'libxcrypt-compat' 'asar')
install=$_pkgname.install
source=(
    "${_pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz"
    "${_pkgname}.desktop"
    "${_pkgname}.sh"
)
sha256sums=('SKIP' 'SKIP' 'SKIP')
options=('!lto')

prepare(){
    cd $srcdir/${_pkgname}-${pkgver}
    corepack pnpm install
}

build(){
    cd $srcdir/${_pkgname}-${pkgver}
    corepack pnpm run build && electron-builder --config electron-builder.config.cjs --linux dir --publish never
}

package() {
    asar extract $srcdir/${_pkgname}-${pkgver}/dist/linux-unpacked/resources/app.asar ${pkgdir}/opt/RouteX
    cp -r $srcdir/${_pkgname}-${pkgver}/extra/sidecar ${pkgdir}/opt/RouteX/resources/
    cp -r $srcdir/${_pkgname}-${pkgver}/extra/files ${pkgdir}/opt/RouteX/resources/
    chmod +x ${pkgdir}/opt/RouteX/resources/files/routex-service
    chmod +sx ${pkgdir}/opt/RouteX/resources/sidecar/mihomo
    chmod +sx ${pkgdir}/opt/RouteX/resources/sidecar/mihomo-alpha
    install -Dm755 "${_pkgname}.sh" "${pkgdir}/usr/bin/${_pkgname}"
    install -Dm644 "${_pkgname}.desktop" "${pkgdir}/usr/share/applications/${_pkgname}.desktop"
    install -Dm644 "${pkgdir}/opt/RouteX/resources/icon.png" "${pkgdir}/usr/share/icons/hicolor/512x512/apps/${_pkgname}.png"

    chown -R root:root ${pkgdir}
}
